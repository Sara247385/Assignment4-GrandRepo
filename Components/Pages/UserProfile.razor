@using Assignment4_App5.Services
@inject AuthenticationStateService AuthService
@implements IDisposable

<div class="cyber-output-panel @(AuthService.IsAuthenticated ? "matrix-authenticated" : "matrix-anonymous") mb-4 text-center">
    @if (AuthService.IsAuthenticated)
    {
        <div class="status-indicator-wrapper animate-fade-in">

            <p class="mt-3 text-white fw-medium font-inter">Welcome, User! You are successfully logged in.</p>
        </div>
    }
    else
    {
        <div class="status-indicator-wrapper animate-fade-in">

            <p class="mt-3 text-white-50 font-inter">Please log in to view your profile.</p>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnStateChange += StateHasChanged;
    }

    public void Dispose()
    {
        AuthService.OnStateChange -= StateHasChanged;
    }
}

<style>
    .cyber-output-panel {
        position: relative;
        border-radius: 16px;
        padding: 30px 20px;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        overflow: hidden;
    }

    .matrix-authenticated {
        background: rgba(0, 242, 254, 0.04) !important;
        border: 1px solid rgba(0, 242, 254, 0.25) !important;
        box-shadow: inset 0 0 20px rgba(0, 242, 254, 0.05);
    }

    .matrix-anonymous {
        background: rgba(239, 68, 68, 0.03) !important;
        border: 1px dashed rgba(239, 68, 68, 0.25) !important;
    }

    .panel-tag {
        font-size: 0.72rem;
        letter-spacing: 1.5px;
        font-weight: 700;
        display: block;
    }

    .text-danger-cyber {
        color: #ef4444;
        text-shadow: 0 0 10px rgba(239, 68, 68, 0.2);
    }

    .font-inter {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 1.05rem;
        letter-spacing: -0.2px;
    }
</style>
