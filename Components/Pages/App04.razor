@page "/app04"
@rendermode InteractiveServer

<div class="cyber-container d-flex align-items-center justify-content-center">
    <div class="orb orb-blue"></div>
    <div class="orb orb-purple"></div>

    <div class="glass-card shadow-2xl animate-fade-in">
        <div class="glass-header text-center position-relative">
            <div class="neon-badge">
                <span class="blink-dot"></span> SYSTEM CORE: APP 04
            </div>
            <h2 class="cyber-title mt-2">Counter App</h2>
            <div class="header-line"></div>
        </div>

        <div class="glass-body p-4">

            <div class="cyber-output-panel matrix-ready mb-4">
                <div class="panel-scanner"></div>

              
                <div class="text-center py-2">
                    <span class="cyber-counter-display">@currentCount</span>
                    <p class="text-white-50 small mt-2 mb-0">Current Count</p>
                </div>
            </div>

            <div class="input-wrapper mb-4">
                <button class="cyber-btn btn-add w-100" @onclick="IncrementCount">
                    <i class="bi bi-plus-circle-fill me-2"></i>Click Me (+1)
                </button>
            </div>

            <div class="input-wrapper mb-4">
                <label class="field-label">
                    <i class="bi bi-sliders text-cyan me-2"></i>Current Count
                </label>
                <div class="cyber-input-group">
                    <input type="number"
                           @bind="currentCount"
                           class="cyber-input"
                           min="0"
                           placeholder="Override pulse register..." />
                    <span class="neon-border-glow"></span>
                </div>
                <small class="text-muted-cyber d-block mt-2" style="font-size: 0.78rem;">

                </small>
            </div>

            <div class="text-center mt-4 d-flex justify-content-between align-items-center">
                <a href="/app03" class="cyber-nav-link">← Task Matrix Engine (App 03)</a>
                <a href="/app05" class="cyber-nav-link text-cyan">State Management (App 05) →</a>
            </div>
        </div>

        <div class="glass-footer d-flex justify-content-between align-items-center">
        </div>
    </div>
</div>

@code {
    // Core state variable (Tracks button clicks and manual inputs)
    private int currentCount = 0;

    // C# Method for handling button click event
    private void IncrementCount()
    {
        currentCount++;
    }
}

<style>
    /* Main Futuristic Canvas Background */
    .cyber-container {
        min-height: 100vh;
        background: #0a0e17;
        position: relative;
        overflow: hidden;
        padding: 40px 15px;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Ambient Decorative Orbs */
    .orb {
        position: absolute;
        width: 350px;
        height: 350px;
        border-radius: 50%;
        filter: blur(130px);
        opacity: 0.25;
        z-index: 0;
        pointer-events: none;
    }

    .orb-blue {
        background: #00f2fe;
        top: 15%;
        left: 20%;
        animation: float-slow 8s infinite alternate;
    }

    .orb-purple {
        background: #9b51e0;
        bottom: 15%;
        right: 20%;
        animation: float-slow 12s infinite alternate-reverse;
    }

    /* Glassmorphism Structural Core Card */
    .glass-card {
        background: rgba(13, 20, 35, 0.65);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        width: 100%;
        max-width: 600px;
        z-index: 10;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7), 0 0 40px rgba(0, 242, 254, 0.05);
        overflow: hidden;
    }

    .glass-header {
        padding: 35px 30px 20px 30px;
    }

    .neon-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(0, 242, 254, 0.08);
        border: 1px solid rgba(0, 242, 254, 0.3);
        color: #00f2fe;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 6px 14px;
        border-radius: 30px;
        letter-spacing: 2px;
        box-shadow: 0 0 15px rgba(0, 242, 254, 0.15);
    }

    .blink-dot {
        width: 6px;
        height: 6px;
        background-color: #00f2fe;
        border-radius: 50%;
        margin-right: 8px;
        display: inline-block;
        animation: blink 1.5s infinite;
    }

    .cyber-title {
        color: #ffffff;
        font-weight: 800;
        font-size: 2rem;
        letter-spacing: -0.5px;
        text-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
    }

    .header-line {
        height: 2px;
        width: 60px;
        background: linear-gradient(90deg, #00f2fe, #4facfe);
        margin: 20px auto 0 auto;
        border-radius: 2px;
    }

    .field-label {
        color: #cbd5e1;
        font-size: 0.88rem;
        font-weight: 600;
        margin-bottom: 10px;
        display: block;
    }

    .cyber-input-group {
        position: relative;
        display: flex;
        align-items: center;
        background: rgba(10, 15, 30, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 6px 16px;
        transition: all 0.4s ease;
    }

    .cyber-input {
        background: transparent;
        border: none;
        outline: none;
        width: 100%;
        padding: 10px 0;
        color: #ffffff;
        font-size: 1rem;
    }
        /* Chrome, Safari, Edge, Opera se numbers arrow hatane ke liye */
        .cyber-input::-webkit-outer-spin-button,
        .cyber-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

    .cyber-input-group:focus-within {
        border-color: #00f2fe;
        box-shadow: 0 0 25px rgba(0, 242, 254, 0.25);
    }

    /* Cyber Action Button */
    .cyber-btn {
        font-weight: 700;
        letter-spacing: 0.5px;
        border: none;
        padding: 14px 24px;
        border-radius: 12px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .btn-add {
        background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
        color: #0a0e17;
        box-shadow: 0 0 20px rgba(0, 242, 254, 0.25);
    }

        .btn-add:hover {
            box-shadow: 0 0 35px rgba(0, 242, 254, 0.45);
            transform: translateY(-2px);
        }

    /* Huge Counter Display Badge */
    .cyber-counter-display {
        font-size: 4.5rem;
        font-weight: 900;
        color: #ffffff;
        font-family: monospace;
        text-shadow: 0 0 30px rgba(0, 242, 254, 0.6), 0 0 10px rgba(255, 255, 255, 0.3);
        line-height: 1;
        display: inline-block;
    }

    /* Output Panel */
    .cyber-output-panel {
        position: relative;
        border-radius: 16px;
        padding: 24px;
        overflow: hidden;
    }

        .cyber-output-panel.matrix-ready {
            background: rgba(0, 242, 254, 0.03);
            border: 1px solid rgba(0, 242, 254, 0.25);
            box-shadow: inset 0 0 20px rgba(0, 242, 254, 0.05), 0 10px 30px rgba(0,0,0,0.3);
        }

    .panel-tag {
        font-size: 0.68rem;
        font-weight: 700;
        color: #00f2fe;
        letter-spacing: 1px;
        display: block;
        margin-bottom: 12px;
        opacity: 0.8;
    }

    .panel-scanner {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, #00f2fe, transparent);
        opacity: 0.4;
        animation: scan 4s linear infinite;
    }

    .cyber-nav-link {
        color: #00f2fe;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.9rem;
        text-shadow: 0 0 10px rgba(0, 242, 254, 0.3);
        transition: all 0.3s ease;
    }

        .cyber-nav-link:hover {
            color: #ffffff;
            text-shadow: 0 0 15px #ffffff;
        }

    .glass-footer {
        background: rgba(5, 8, 16, 0.5);
        padding: 20px 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .text-muted-cyber {
        color: #475569;
        font-weight: 500;
    }

    .text-cyan {
        color: #00f2fe;
    }

    @@keyframes blink {
        50% {
            opacity: 0;
        }
    }

    @@keyframes scan {
        0% {
            top: 0%;
        }

        50% {
            top: 100%;
        }

        100% {
            top: 0%;
        }
    }

    @@keyframes float-slow {
        0% {
            transform: translateY(0px) scale(1);
        }

        100% {
            transform: translateY(-30px) scale(1.1);
        }
    }

    .animate-fade-in {
        animation: fadeIn 0.6s ease-out forwards;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>