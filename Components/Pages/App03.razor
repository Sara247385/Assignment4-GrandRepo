@page "/app03"
@rendermode InteractiveServer

<div class="cyber-container d-flex align-items-center justify-content-center">
    <div class="orb orb-blue"></div>
    <div class="orb orb-purple"></div>

    <div class="glass-card shadow-2xl animate-fade-in">
        <div class="glass-header text-center position-relative">
            <div class="neon-badge">
                <span class="blink-dot"></span> SYSTEM CORE: APP 03
            </div>
            <h2 class="cyber-title mt-2">Task Matrix Engine</h2>
            <div class="header-line"></div>
        </div>

        <div class="glass-body p-4">
            <div class="input-wrapper mb-4">
                <label class="field-label">
                    <i class="bi bi-terminal-fill text-cyan me-2"></i>Enter Task
                </label>
                <div class="cyber-input-group">
                    <input type="text"
                           @bind="newTask"
                           class="cyber-input"
                           placeholder="Enter task objective..." />
                    <span class="neon-border-glow"></span>
                </div>
                <div class="mt-3 d-flex gap-2">
                    <button class="cyber-btn btn-add" @onclick="AddTask">
                        <i class="bi bi-plus-circle-fill me-2"></i>ADD TASK
                    </button>
                    <button class="cyber-btn btn-clear" @onclick="ClearAllTasks" disabled="@(!taskList.Any())">
                        <i class="bi bi-trash3-fill me-2"></i>CLEAR ALL
                    </button>
                </div>
            </div>

            <div class="cyber-output-panel @(taskList.Any() ? "matrix-ready" : "matrix-waiting")">
                <div class="panel-scanner"></div>

              
                @if (taskList.Any())
                {
                    <ul class="task-vector-list">
                        @foreach (var task in taskList)
                        {
                            <li class="task-item animate-fade-in">
                                <span class="task-bullet">></span>
                                <span class="task-text">@task</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <h3 class="output-greeting text-center py-3" style="font-size: 1.1rem; color: #475569;">
                        <span class="cursor">>_</span> No tasks available.
                    </h3>
                }
            </div>

            <div class="text-center mt-4 d-flex justify-content-between align-items-center">
                <a href="/app02" class="cyber-nav-link">← Back to Validation Engine (App 02)</a>
                <a href="/app04" class="cyber-nav-link text-cyan">Pulse Counter Tracker (App 04) →</a>
            </div>
        </div>

        <div class="glass-footer d-flex justify-content-between align-items-center">
        </div>
    </div>
</div>

@code {
    // Two-Way Binding Variable
    private string newTask = string.Empty;

    // One-Way Binding Data Source List
    private List<string> taskList = new List<string>();

    private void AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTask))
        {
            taskList.Add(newTask.Trim());
            newTask = string.Empty; // Input field clear karne ke liye
        }
    }

    private void ClearAllTasks()
    {
        taskList.Clear(); // Saari items list se delete karne ke liye
    }
}

<style>
    /* Main Futuristic Canvas Background */
    .cyber-container {
        min-height: 100vh;
        background: #0a0e17;
        position: relative;
        overflow: hidden;
        padding: 40px 15px;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Ambient Decorative Orbs */
    .orb {
        position: absolute;
        width: 350px;
        height: 350px;
        border-radius: 50%;
        filter: blur(130px);
        opacity: 0.25;
        z-index: 0;
        pointer-events: none;
    }

    .orb-blue {
        background: #00f2fe;
        top: 15%;
        left: 20%;
        animation: float-slow 8s infinite alternate;
    }

    .orb-purple {
        background: #9b51e0;
        bottom: 15%;
        right: 20%;
        animation: float-slow 12s infinite alternate-reverse;
    }

    /* Glassmorphism Structural Core Card CSS */
    .glass-card {
        background: rgba(13, 20, 35, 0.65);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        width: 100%;
        max-width: 600px;
        z-index: 10;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7), 0 0 40px rgba(0, 242, 254, 0.05);
        overflow: hidden;
    }

    .glass-header {
        padding: 35px 30px 20px 30px;
    }

    .neon-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(0, 242, 254, 0.08);
        border: 1px solid rgba(0, 242, 254, 0.3);
        color: #00f2fe;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 6px 14px;
        border-radius: 30px;
        letter-spacing: 2px;
        box-shadow: 0 0 15px rgba(0, 242, 254, 0.15);
    }

    .blink-dot {
        width: 6px;
        height: 6px;
        background-color: #00f2fe;
        border-radius: 50%;
        margin-right: 8px;
        display: inline-block;
        animation: blink 1.5s infinite;
    }

    .cyber-title {
        color: #ffffff;
        font-weight: 800;
        font-size: 2rem;
        letter-spacing: -0.5px;
        text-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
    }

    .header-line {
        height: 2px;
        width: 60px;
        background: linear-gradient(90deg, #00f2fe, #4facfe);
        margin: 20px auto 0 auto;
        border-radius: 2px;
    }

    .field-label {
        color: #cbd5e1;
        font-size: 0.88rem;
        font-weight: 600;
        margin-bottom: 10px;
        display: block;
    }

    .cyber-input-group {
        position: relative;
        display: flex;
        align-items: center;
        background: rgba(10, 15, 30, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 6px 16px;
    }

    .cyber-input {
        background: transparent;
        border: none;
        outline: none;
        width: 100%;
        padding: 10px 0;
        color: #ffffff;
        font-size: 1rem;
    }

        .cyber-input::placeholder {
            color: #4b5563;
        }

    .cyber-input-group:focus-within {
        border-color: #00f2fe;
        box-shadow: 0 0 25px rgba(0, 242, 254, 0.25);
    }

    /* Cyber Buttons styling */
    .cyber-btn {
        font-weight: 700;
        letter-spacing: 0.5px;
        border: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-size: 0.88rem;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .btn-add {
        background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
        color: #0a0e17;
        flex: 2;
        box-shadow: 0 0 20px rgba(0, 242, 254, 0.25);
    }

        .btn-add:hover {
            box-shadow: 0 0 35px rgba(0, 242, 254, 0.45);
            transform: translateY(-1px);
        }

    .btn-clear {
        background: rgba(255, 74, 90, 0.1);
        border: 1px solid rgba(255, 74, 90, 0.3);
        color: #ff4a5a;
        flex: 1;
    }

        .btn-clear:hover:not(:disabled) {
            background: rgba(255, 74, 90, 0.25);
            color: #ffffff;
            box-shadow: 0 0 20px rgba(255, 74, 90, 0.3);
        }

        .btn-clear:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

    /* Output Section & List Architecture */
    .cyber-output-panel {
        position: relative;
        border-radius: 16px;
        padding: 24px;
        overflow: hidden;
    }

        .cyber-output-panel.matrix-waiting {
            background: rgba(255, 255, 255, 0.02);
            border: 1px dashed rgba(255, 255, 255, 0.15);
        }

        .cyber-output-panel.matrix-ready {
            background: rgba(0, 242, 254, 0.02);
            border: 1px solid rgba(0, 242, 254, 0.2);
        }

    .panel-tag {
        font-size: 0.68rem;
        font-weight: 700;
        color: #475569;
        letter-spacing: 1px;
        display: block;
        margin-bottom: 12px;
    }

    .panel-scanner {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, #00f2fe, transparent);
        opacity: 0.3;
        animation: scan 4s linear infinite;
    }

    .task-vector-list {
        list-style: none;
        padding: 0;
        margin: 0;
        max-height: 220px;
        overflow-y: auto;
    }

    .task-item {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 10px 16px;
        border-radius: 10px;
        margin-bottom: 8px;
    }

    .task-bullet {
        color: #00f2fe;
        font-weight: 700;
        margin-right: 12px;
        text-shadow: 0 0 10px rgba(0, 242, 254, 0.6);
    }

    .task-text {
        color: #e2e8f0;
        font-size: 0.95rem;
    }

    .cyber-nav-link {
        color: #cbd5e1;
        font-weight: 500;
        text-decoration: none;
        font-size: 0.88rem;
        transition: all 0.3s ease;
    }

        .cyber-nav-link:hover {
            color: #00f2fe;
            text-shadow: 0 0 10px rgba(0, 242, 254, 0.4);
        }

    .glass-footer {
        background: rgba(5, 8, 16, 0.5);
        padding: 20px 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .faculty-tag {
        font-size: 0.78rem;
    }

    .text-muted-cyber {
        color: #475569;
        font-weight: 500;
    }

    .text-cyan {
        color: #00f2fe;
    }

    .text-purple-glow {
        color: #c084fc;
        text-shadow: 0 0 10px rgba(192, 132, 252, 0.3);
    }

    @@keyframes blink {
        50% {
            opacity: 0;
        }
    }

    @@keyframes scan {
        0% {
            top: 0%;
        }

        50% {
            top: 100%;
        }

        100% {
            top: 0%;
        }
    }

    @@keyframes float-slow {
        0% {
            transform: translateY(0px);
        }

        100% {
            transform: translateY(-20px);
        }
    }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-out forwards;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
