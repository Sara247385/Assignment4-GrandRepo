@using Assignment4_App6.Services
@inject NotificationService NotificationEngine
@inject NotificationConfig Config
@implements IDisposable

<div class="display-zone animate-fade-in mt-2">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="text-cyan font-monospace" style="font-size: 0.72rem; letter-spacing:1px;">[ LIVE ROUTER TELEMETRY STREAM ]</span>
        <span class="badge font-monospace style-tag">MODE: @Config.NotificationStyle.ToUpper()</span>
    </div>

    @if (items == null)
    {
        <div class="text-center text-muted py-3 small font-monospace">Synchronizing Data Relays...</div>
    }
    else
    {
        <div class="logs-stack">
            @foreach (var log in items)
            {
                <div class="log-card mb-2 @(Config.NotificationStyle == "Compact" ? "p-2 compact-view" : "p-3 detailed-view")">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                        <span class="fw-medium text-white" style="font-size: 0.9rem; line-height: 1.4;">
                            <i class="bi bi-terminal-fill me-2 @(log.Severity == "CRITICAL" ? "text-danger-glow" : "text-cyan-glow")"></i>
                            @log.Message
                        </span>

                        @if (Config.NotificationStyle == "Detailed")
                        {
                            <span class="text-muted font-monospace text-nowrap" style="font-size: 0.7rem; margin-top: 3px;">@log.Timestamp.ToString("HH:mm:ss")</span>
                        }
                    </div>

                    @if (Config.NotificationStyle == "Detailed")
                    {
                        <div class="mt-2 pt-2 border-top-secondary-cyber d-flex justify-content-between align-items-center" style="font-size: 0.72rem;">
                            <span class="text-white-50">SECURITY INDEX: </span>
                            <span class="fw-bold font-monospace @(log.Severity == "CRITICAL" ? "text-danger-glow" : "text-success-glow")">[@log.Severity]</span>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<NotificationItem>? items;

    protected override async Task OnInitializedAsync()
    {
        Config.OnConfigChanged += RefreshUI;
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        items = await NotificationEngine.GetNotificationsAsync();
    }

    private async void RefreshUI()
    {
        await LoadLogs();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Config.OnConfigChanged -= RefreshUI;
    }
}

<style>
    .style-tag {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        color: #929aab;
        font-size: 0.68rem;
        padding: 4px 8px;
        border-radius: 6px;
    }

    .log-card {
        background: rgba(255,255,255,0.02) !important;
        border-radius: 12px;
        transition: all 0.25s ease;
    }

    .detailed-view {
        border-left: 3px solid #00f2fe !important;
    }

    .compact-view {
        border-left: 2px dashed rgba(255,255,255,0.15) !important;
    }

    .border-top-secondary-cyber {
        border-top: 1px solid rgba(255,255,255,0.08) !important;
    }

    .text-cyan-glow {
        color: #00f2fe !important;
        text-shadow: 0 0 8px rgba(0, 242, 254, 0.4);
    }

    .text-danger-glow {
        color: #ef4444 !important;
        text-shadow: 0 0 8px rgba(239, 68, 68, 0.4);
    }

    .text-success-glow {
        color: #10b981 !important;
        text-shadow: 0 0 8px rgba(16, 185, 129, 0.4);
    }
</style>