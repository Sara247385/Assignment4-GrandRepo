@using Assignment4_App6.Services
@inject NotificationConfig Config

<div class="settings-control-box p-3 mb-4" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px;">
  

    <div class="mb-3 text-start">
        <label class="text-white-50 small mb-1" style="font-size:0.8rem;"><i class="bi bi-sliders text-cyan me-2"></i>Default Log Count Limit</label>
        <div class="cyber-field-container">
            <input type="number" min="1" max="5" class="cyber-input-element"
                   value="@Config.DefaultNumberOfNotifications"
                   @onchange="UpdateCount" />
        </div>
    </div>

    <div class="mb-2 text-start">
        <label class="text-white-50 small mb-1" style="font-size:0.8rem;"><i class="bi bi-eye-fill text-cyan me-2"></i>Render Pipeline Interface</label>
        <div class="cyber-field-container">
            <select class="cyber-input-element select-arrow-fix" value="@Config.NotificationStyle" @onchange="UpdateStyle">
             
                <option value="Detailed">Detailed </option>
                <option value="Compact">Compact </option>
            </select>
        </div>
    </div>
</div>

@code {
    private void UpdateCount(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
        {
            Config.DefaultNumberOfNotifications = val;
            Config.TriggerUpdate();
        }
    }

    private void UpdateStyle(ChangeEventArgs e)
    {
        Config.NotificationStyle = e.Value?.ToString() ?? "Detailed";
        Config.TriggerUpdate();
    }
}

<style>
    .cyber-field-container {
        position: relative;
        background: rgba(10, 14, 23, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        padding: 2px 10px;
        transition: border-color 0.3s ease;
    }

        .cyber-field-container:focus-within {
            border-color: rgba(0, 242, 254, 0.4);
        }

    .cyber-input-element {
        background: transparent !important;
        border: none !important;
        color: #ffffff !important;
        width: 100%;
        padding: 10px 5px;
        font-size: 0.92rem;
        outline: none !important;
    }

    .select-arrow-fix option {
        background: #0d1423 !important;
        color: #ffffff;
    }
</style>